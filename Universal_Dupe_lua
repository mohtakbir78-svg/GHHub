                local harvested=doAutoFarm()
                if harvested and harvested>0 then
                    addLog("🌱 Farm: "..harvested.." item",LIME)
                end
            end)
        end

        -- Auto Sell + Remote Spam loop
        if autoSellOn or remSpamOn then
            pcall(function()
                -- TP ke sell NPC dulu kalau ada
                local c,hum,root=getChar()
                if root then
                    for _,obj in ipairs(workspace:GetDescendants()) do
                        local n=obj.Name:lower()
                        for _,kw in ipairs(sellNPCKeywords) do
                            if n:find(kw) then
                                local part=obj
                                if obj:IsA("Model") then part=obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart") end
                                if part and part.Parent then
                                    local dist=(part.Position-root.Position).Magnitude
                                    if dist<50 then
                                        root.CFrame=CFrame.new(part.Position)+Vector3.new(0,3,0)
                                        pcall(function() firetouchinterest(part,root,0) task.wait(0.02) firetouchinterest(part,root,1) end)
                                    end
                                end
                                break
                            end
                        end
                    end
                end

                -- Fire semua sell remote
                if remSpamOn then
                    fireSellRemotes()
                    sellCount=sellCount+1
                end

                -- Update log
                if remSpamOn then
                    remCountLbl.Text="Total fire: "..totalFire
                    if #sellRemotes>0 then
                        remLogLbl.Text="Top: "..sellRemotes[1].name
                        remLogLbl.TextColor3=LIME
                    end
                end
            end)
        end

        if autoFarmOn or autoSellOn or remSpamOn then
            loopCount=loopCount+1
            loopLbl.Text="Loop: "..loopCount.."x  |  Sell: "..sellCount.."x  |  Fire: "..totalFire
        end

        task.wait(farmInstant and 0.3 or 1)
    end
end)
