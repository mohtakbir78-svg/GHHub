    task.spawn(function()
        scanRemotes()
        mScanBtn.Text="✅ Done"
        task.delay(2,function() mScanBtn.Text="🔍 Scan Remote" end)
    end)
end)

-- Fire dupe
local moneyDelay=0.05 local fireCount=0 local totalFire=0

local function dupeItem(itemName, amount)
    if #sellRemotes==0 then scanRemotes() end
    local params={
        {itemName},{itemName,amount or 9999},
        {{name=itemName,amount=amount or 9999}},
        {{name=itemName,count=amount or 9999}},
        {P,itemName,amount or 9999},{P.Name,itemName,amount or 9999},
        {"all"},{"All"},{},{itemName,amount or 9999,true},
    }
    for _,remInfo in ipairs(sellRemotes) do
        local r=remInfo.r if not r or not r.Parent then continue end
        for _,pm in ipairs(params) do
            pcall(function()
                if r:IsA("RemoteEvent") then r:FireServer(table.unpack(pm))
                else r:InvokeServer(table.unpack(pm)) end
            end)
            fireCount=fireCount+1
        end
        task.wait(moneyDelay)
    end
    for _,rem in ipairs(allRemotes) do
        pcall(function()
            if rem:IsA("RemoteEvent") then
                rem:FireServer(itemName,amount or 9999)
                rem:FireServer({name=itemName,amount=amount or 9999})
            end
        end)
    end
    totalFire=totalFire+1
    mSpamLbl.Text="Fire: "..fireCount
end

