-- AUTO DUPE LOOP
autoDupeBtn.MouseButton1Click:Connect(function()
    autoDuping = not autoDuping
    if autoDuping then
        autoDupeBtn.Text="⏹ STOP AUTO DUPE"
        autoDupeBtn.BackgroundColor3=R
        task.spawn(function()
            while autoDuping do
                if selectedItem and #foundRemotes > 0 then
                    tryDupe(selectedItem, amtVal)
                    task.wait(0.5)
                else
                    dupeStatusLbl.Text="⚠️ Pilih item & scan remote dulu!"
                    dupeStatusLbl.TextColor3=R
                    task.wait(1)
                end
            end
        end)
    else
        autoDupeBtn.Text="🔁 AUTO DUPE (loop)"
        autoDupeBtn.BackgroundColor3=Color3.fromRGB(100,20,160)
        dupeStatusLbl.Text="⏹ Auto dupe berhenti"
        dupeStatusLbl.TextColor3=GR
    end
end)
