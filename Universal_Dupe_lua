-- Scan remote
local sellRemotes={} local allRemotes={}
local sellKw={"sell","harvest","collect","submit","trade","shop","market","vendor","give","exchange","buy","purchase","add","reward","item","seed","gear","plant","complete"}

local function scanRemotes()
    sellRemotes={} allRemotes={}
    for _,v in ipairs(RSt:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            table.insert(allRemotes,v)
            local n=v.Name:lower() local score=0
            for _,kw in ipairs(sellKw) do if n:find(kw) then score=score+1 end end
            if score>0 then table.insert(sellRemotes,{r=v,n=v.Name,s=score}) end
        end
    end
    table.sort(sellRemotes,function(a,b) return a.s>b.s end)
    mRemLbl.Text="Remote: "..#sellRemotes.."/"..#allRemotes mRemLbl.TextColor3=LIME
    for i=1,math.min(3,#sellRemotes) do log("⭐ "..sellRemotes[i].n,LIME) end
end

mScanBtn.MouseButton1Click:Connect(function()
