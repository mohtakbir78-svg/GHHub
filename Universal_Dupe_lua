        if nearest.Parent then
            for _,pp in ipairs(nearest.Parent:GetDescendants()) do
                if pp:IsA("ProximityPrompt") then pcall(function() fireproximityprompt(pp) end) end
            end
        end
        tpSellBtn.Text="✅ TP ke NPC!"
        addLog("TP ke: "..nearest.Name.." (dist:"..math.floor(nearDist)..")",LIME)
    else
        tpSellBtn.Text="⚠️ NPC tidak ketemu"
        addLog("Sell NPC tidak ditemukan di workspace",R)
