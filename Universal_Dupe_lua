-- TP sell NPC
local sellNpcKw={"shop","market","sell","vendor","merchant","trader","store","npc"}
local function tpSellNpc()
    local _,_,root=getChar() if not root then return end
    for _,obj in ipairs(WS:GetDescendants()) do
        local nm=obj.Name:lower() local match=false
        for _,kw in ipairs(sellNpcKw) do if nm:find(kw) then match=true break end end
        if not match then continue end
        local part=obj
        if obj:IsA("Model") then part=obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart") end
        if part and part.Parent then
            root.CFrame=CFrame.new(part.Position)+Vector3.new(0,3,0)
            pcall(function() firetouchinterest(part,root,0) task.wait(0.05) firetouchinterest(part,root,1) end)
            for _,pp in ipairs(obj:GetDescendants()) do
                if pp:IsA("ProximityPrompt") then pcall(function() fireproximityprompt(pp) end) end
            end
            return true
        end
    end
end

