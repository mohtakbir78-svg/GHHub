-- MONITOR MONEY (tampilkan uang realtime)
-- ================================
local function getMoneyValue()
    -- Coba berbagai cara dapat nilai money
    local moneyNames={"Money","Coins","Cash","Gold","Gems","Currency","Bucks","Points","Shillings"}
    -- Cek leaderstats
    local ls=P:FindFirstChild("leaderstats")
    if ls then
        for _,name in ipairs(moneyNames) do
            local v=ls:FindFirstChild(name)
            if v then return v.Value,name end
        end
        -- Cek semua children leaderstats
        for _,v in ipairs(ls:GetChildren()) do
            if v:IsA("IntValue") or v:IsA("NumberValue") then
                return v.Value, v.Name
            end
        end
    end
    -- Cek langsung di player
    for _,name in ipairs(moneyNames) do
        local v=P:FindFirstChild(name,true)
        if v and (v:IsA("IntValue") or v:IsA("NumberValue")) then
            return v.Value, name
        end
    end
    return nil,"?"
end

task.spawn(function()
    local lastMoney=nil
    while true do
        pcall(function()
            local val,name=getMoneyValue()
            if val then
                if lastMoney and val~=lastMoney then
                    local diff=val-lastMoney
                    local sign=diff>0 and "+" or ""
                    addLog(sign..diff.." "..name.." (total: "..val..")", diff>0 and LIME or R)
                end
                lastMoney=val
                moneyLbl.Text="💰 "..name..": "..tostring(val)
                moneyLbl.TextColor3=GO
            end
        end)
        task.wait(0.5)
    end
end)

-- ================================
-- SCAN REMOTE SELL
-- ================================
local sellRemotes={}
local sellKeywords={"sell","harvest","collect","submit","trade","exchange","shop","market","vendor","npc","give","complete","finish","turn"}

local function scanSellRemotes()
    sellRemotes={}
    for _,v in ipairs(RSt:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local n=v.Name:lower()
            local score=0
            for _,kw in ipairs(sellKeywords) do
                if n:find(kw) then score=score+1 end
            end
            if score>0 then
                table.insert(sellRemotes,{r=v,name=v.Name,score=score})
            end
        end
    end
    table.sort(sellRemotes,function(a,b) return a.score>b.score end)
    remStLbl.Text="Remote ditemukan: "..#sellRemotes
    remStLbl.TextColor3=LIME
    for i=1,math.min(3,#sellRemotes) do
        addLog("⭐ "..sellRemotes[i].name.." (score:"..sellRemotes[i].score..")",LIME)
    end
    return sellRemotes
end

scanRemBtn.MouseButton1Click:Connect(function()
    scanRemBtn.Text="⏳"
    task.spawn(function()
        scanSellRemotes()
        scanRemBtn.Text="✅ Done"
        task.delay(2,function() scanRemBtn.Text="🔍 Scan" end)
    end)
end)

-- ================================
-- FUNGSI: FIRE SELL REMOTES
-- ================================
local totalFire=0
local sellDelay=0.1

local function fireSellRemotes()
    if #sellRemotes==0 then scanSellRemotes() end
    local c,hum,root=getChar()

    -- Kumpulkan semua item di inventory player
    local itemsToSell={}
    local backpack=P:FindFirstChildOfClass("Backpack")
    if backpack then
        for _,tool in ipairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then table.insert(itemsToSell,tool.Name) end
        end
    end
    if P.Character then
        for _,tool in ipairs(P.Character:GetChildren()) do
            if tool:IsA("Tool") then table.insert(itemsToSell,tool.Name) end
        end
    end

    -- Format parameter yang dicoba
    local params={}
    for _,itemName in ipairs(itemsToSell) do
        table.insert(params,{itemName})
        table.insert(params,{itemName,1})
        table.insert(params,{itemName,9999})
        table.insert(params,{{name=itemName}})
        table.insert(params,{{name=itemName,amount=9999}})
    end
    -- Tambah param kosong dan umum
    table.insert(params,{})
    table.insert(params,{"all"})
    table.insert(params,{"All"})
    table.insert(params,{P})
    table.insert(params,{P.Name})

    for _,remInfo in ipairs(sellRemotes) do
        local remote=remInfo.r
        if not remote or not remote.Parent then continue end
        for _,param in ipairs(params) do
            pcall(function()
                if remote:IsA("RemoteEvent") then
                    remote:FireServer(table.unpack(param))
                else
                    remote:InvokeServer(table.unpack(param))
                end
            end)
            totalFire=totalFire+1
        end
        task.wait(sellDelay)
    end
end

-- ================================
-- FUNGSI: AUTO FARM (TP ke semua tanaman)
-- ================================
local farmInstant=false
local farmCount=0

local cropKeywords={
    "plant","crop","harvest","tree","bush","flower","fruit",
    "carrot","strawberry","blueberry","tomato","corn","watermelon",
    "pumpkin","apple","bamboo","coconut","rose","sunflower",
    "mushroom","pepper","beet","grape","mango","pineapple","wheat",
    "seed","sprout","grown","ready","ripe","mature","plot","bed","farmplot"
}

local function doAutoFarm()
    local c,hum,root=getChar() if not root then return end
    farmCount=farmCount+1
    local harvested=0

    for _,obj in ipairs(workspace:GetDescendants()) do
        local n=obj.Name:lower()
        local match=false
        for _,kw in ipairs(cropKeywords) do
            if n:find(kw) then match=true break end
        end
        if not match then continue end

        local part=nil
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then part=obj
        elseif obj:IsA("Model") then part=obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
        end
        if not part or not part.Parent then continue end

        if farmInstant then
            root.CFrame=CFrame.new(part.Position)+Vector3.new(0,3,0)
            task.wait(0.05)
        end

        -- Fire touch
        pcall(function() firetouchinterest(part,root,0) task.wait(0.02) firetouchinterest(part,root,1) end)

        -- Fire ProximityPrompt
        for _,pp in ipairs(obj:GetDescendants()) do
            if pp:IsA("ProximityPrompt") then
                pcall(function() fireproximityprompt(pp) end)
            end
        end

        -- TP jika instant
        if farmInstant then
            root.CFrame=CFrame.new(part.Position)+Vector3.new(0,3,0)
        end

        harvested=harvested+1
        if not farmInstant then task.wait(0.1) end
    end

    return harvested
end

