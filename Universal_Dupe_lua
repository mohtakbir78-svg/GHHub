scanBtn.MouseButton1Click:Connect(function()
    foundRemotes={}
    clearLog()
    scanStatusLbl.Text="Status: Scanning..."
    scanStatusLbl.TextColor3=GO
    scanBtn.Text="⏳ Scanning..."
    scanBtn.BackgroundColor3=GO

    task.spawn(function()
        -- Scan ReplicatedStorage
        local checked=0
        for _,v in ipairs(RSt:GetDescendants()) do
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                local n=v.Name:lower()
                -- Prioritaskan yang berkaitan dengan economy/item
                local priority = 0
                local keywords={"buy","sell","give","add","money","coin","gold","cash","gem","currency","item","plant","harvest","shop","purchase","reward","dupe","stack","amount","quantity","trade"}
                for _,kw in ipairs(keywords) do
                    if n:find(kw) then priority=priority+1 end
                end
                if priority > 0 then
                    table.insert(foundRemotes,{remote=v, name=v.Name, priority=priority, type=v.ClassName})
                    addLog("⭐["..v.ClassName.."] "..v.Name.." (score:"..priority..")", LIME)
                else
                    table.insert(foundRemotes,{remote=v, name=v.Name, priority=0, type=v.ClassName})
                    addLog("  ["..v.ClassName.."] "..v.Name, GR)
                end
                checked=checked+1
                task.wait(0.01)
            end
        end

        -- Sort by priority
        table.sort(foundRemotes, function(a,b) return a.priority > b.priority end)

        remoteCountLbl.Text="Remote ditemukan: "..#foundRemotes.." ("..checked.." total)"
        remoteCountLbl.TextColor3=CY
        scanStatusLbl.Text="✅ Scan selesai! Remote prioritas tinggi di atas"
        scanStatusLbl.TextColor3=G
        scanBtn.Text="🔍 Scan Semua Remote"
        scanBtn.BackgroundColor3=Color3.fromRGB(30,70,160)
    end)
end)

-- ================================
-- LOGIKA DUPE
-- ================================
local autoDuping = false

-- Semua kemungkinan format parameter yang dicoba
local function buildParams(itemName, amount)
    return {
        -- Format 1: nama + jumlah
        {itemName, amount},
        -- Format 2: nama saja
        {itemName},
        -- Format 3: table item
        {{name=itemName, amount=amount}},
        {{name=itemName, count=amount}},
        {{itemName=itemName, amount=amount}},
        -- Format 4: jumlah saja
        {amount},
        -- Format 5: dengan player
        {P, itemName, amount},
        {P.Name, itemName, amount},
        {P.UserId, itemName, amount},
        -- Format 6: string saja
        {itemName.."|"..amount},
        -- Format 7: kosong (trigger event)
        {},
        -- Format 8: amount besar langsung
        {itemName, 9999},
        {itemName, math.huge},
    }
end

local function tryDupe(itemName, amount)
    local success = 0
    local tried = 0

    dupeStatusLbl.Text="🔥 Mencoba dupe: "..itemName
    dupeStatusLbl.TextColor3=GO

    local paramSets = buildParams(itemName, amount)

    -- Coba semua remote yang ditemukan
    for _, remInfo in ipairs(foundRemotes) do
        local remote = remInfo.remote
        if not remote or not remote.Parent then continue end

        for _, params in ipairs(paramSets) do
            tried = tried + 1
            pcall(function()
                if remote:IsA("RemoteEvent") then
                    remote:FireServer(table.unpack(params))
                elseif remote:IsA("RemoteFunction") then
                    remote:InvokeServer(table.unpack(params))
                end
            end)
            task.wait(0.02)
        end
    end

    -- Juga coba langsung fire dengan nama umum
    local commonRemoteNames = {
        "AddItem","GiveItem","BuyItem","AddMoney","GiveMoney",
        "AddCoins","GiveCoins","Purchase","AddCurrency",
        "Sell","SellAll","HarvestAll","CollectAll",
        "AddToInventory","GiveToPlayer","RewardPlayer",
    }
    for _, rName in ipairs(commonRemoteNames) do
        local re = RSt:FindFirstChild(rName, true)
        if re then
            pcall(function()
                if re:IsA("RemoteEvent") then
                    re:FireServer(itemName, amount)
                    re:FireServer(P, itemName, amount)
                    re:FireServer({item=itemName, amount=amount})
                elseif re:IsA("RemoteFunction") then
                    re:InvokeServer(itemName, amount)
                end
            end)
            tried = tried + 1
        end
    end

    dupeStatusLbl.Text="✅ Selesai! "..tried.." kombinasi dicoba"
    dupeStatusLbl.TextColor3=G
    return tried
end

