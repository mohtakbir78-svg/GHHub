-- Auto Farm
local cropKw={"plant","crop","harvest","tree","bush","carrot","strawberry","blueberry","tomato","corn","watermelon","pumpkin","apple","bamboo","coconut","rose","sunflower","mushroom","pepper","wheat","seed","sprout","grown","ripe","plot","bed","fruit","flower"}
local farmInstant=false local farmTotal=0

local function doFarm()
    local _,_,root=getChar() if not root then return 0 end
    local n=0
    for _,obj in ipairs(WS:GetDescendants()) do
        local nm=obj.Name:lower() local match=false
        for _,kw in ipairs(cropKw) do if nm:find(kw) then match=true break end end
        if not match then continue end
        local part=nil
        if obj:IsA("BasePart") or obj:IsA("MeshPart") then part=obj
        elseif obj:IsA("Model") then part=obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart") end
        if not part or not part.Parent then continue end
        if farmInstant then root.CFrame=CFrame.new(part.Position)+Vector3.new(0,3,0) task.wait(0.02) end
        pcall(function() firetouchinterest(part,root,0) task.wait(0.01) firetouchinterest(part,root,1) end)
        for _,pp in ipairs(obj:GetDescendants()) do
            if pp:IsA("ProximityPrompt") then pcall(function() fireproximityprompt(pp) end) end
        end
        n=n+1 task.wait(farmInstant and 0 or 0.04)
    end
    farmTotal=farmTotal+n fCntLbl.Text="Harvest: "..farmTotal return n
end

